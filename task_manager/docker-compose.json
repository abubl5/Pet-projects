{
  "version": "3.9",
  "services": {
    "db": {
      "image": "postgres:15",
      "environment": {
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres",
        "POSTGRES_DB": "tasks"
      },
      "ports": ["5432:5432"]
    },
    "app": {
      "build": ".",
      "depends_on": ["db"],
      "environment": {
        "DATABASE_URL": "postgresql://postgres:postgres@db:5432/tasks"
      },
      "ports": ["8000:8000"]
    }
  }
}